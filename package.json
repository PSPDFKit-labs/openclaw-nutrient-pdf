{
  "name": "@nutrient-sdk/openclaw-nutrient-pdf",
  "version": "2026.4.5",
  "private": false,
  "description": "Nutrient-powered PDF extraction for OpenClaw. Dramatically better table, heading, and reading-order preservation compared to the default pdfjs extractor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pspdfkit-labs/openclaw-nutrient-pdf"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "pdf",
    "pdf-extraction",
    "pdf-table-extraction",
    "pdf-to-markdown",
    "pdfjs-alternative",
    "nutrient",
    "extraction",
    "ai-pdf",
    "llm-pdf",
    "table-extraction",
    "structured-markdown"
  ],
  "files": [
    "index.ts",
    "api.ts",
    "src/",
    "assets/",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "dependencies": {
    "@pspdfkit/pdf-to-markdown": "1.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@nutrient-sdk/openclaw-nutrient-pdf",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "compat": {
      "pluginApi": ">=2026.4.1"
    }
  }
}
