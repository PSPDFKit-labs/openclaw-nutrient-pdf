{
  "name": "@nutrient-sdk/openclaw-nutrient-pdf",
  "version": "2026.6.3",
  "private": false,
  "description": "Explicit Nutrient-powered PDF extraction tool and CLI for OpenClaw. Adds an on-demand nutrient_pdf_extract tool and an openclaw nutrient-pdf CLI for high-fidelity table, heading, and reading-order extraction.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pspdfkit-labs/openclaw-nutrient-pdf.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "pdf",
    "pdf-extraction",
    "pdf-table-extraction",
    "pdf-to-markdown",
    "pdfjs-alternative",
    "nutrient",
    "extraction",
    "ai-pdf",
    "llm-pdf",
    "table-extraction",
    "structured-markdown"
  ],
  "files": [
    "dist/",
    "index.ts",
    "api.ts",
    "src/nutrient-cli.ts",
    "src/config.ts",
    "assets/",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@pspdfkit/pdf-to-markdown": "0.2.2",
    "@sinclair/typebox": "0.34.49"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.4.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@nutrient-sdk/openclaw-nutrient-pdf",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "compat": {
      "pluginApi": ">=2026.4.1",
      "minGatewayVersion": "2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.6.2",
      "pluginSdkVersion": "2026.6.2"
    }
  }
}
